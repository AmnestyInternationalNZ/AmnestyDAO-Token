{
  "name": "hrdao-mvp",
  "version": "0.0.3",
  "description": "Human Rights DAO Application",
  "productName": "Human Rights DAO",
  "author": "Matou Collective",
  "license": "AGPL-3.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint --ext .js,.ts,.vue ./",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "quasar dev",
    "dev:electron": "quasar dev -m electron",
    "dev:ios": "npx quasar dev -m capacitor -T ios",
    "dev:android": "npx quasar dev -m capacitor -T android",
    "dev:android:watch": "npx quasar dev -m capacitor -T android --watch",
    "update-version": "node scripts/update-version.js",
    "generate:icons": "node src-capacitor/generate-icons.js",
    "generate:electron-icons": "node scripts/generate-electron-icons.js",
    "build": "quasar build",
    "build:prod": "NODE_ENV=production quasar build",
    "build:electron": "quasar build -m electron",
    "build:android:debug": "NODE_ENV=development quasar build && cd src-capacitor && npx cap sync android && cd android && ./gradlew clean assembleDebug",
    "build:android:prod": "cd src-capacitor/android && ./build-release.sh",
    "serve:prod": "npx serve dist/spa -l 9000",
    "build:prod:serve": "npm run build:prod && npm run serve:prod",
    "i18n:push": "dotenv -e .env -- npx crowdin upload sources",
    "i18n:pull": "dotenv -e .env -- npx crowdin download"
  },
  "dependencies": {
    "@apollo/client": "^3.13.8",
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/barcode-scanner": "^2.2.0",
    "@capacitor/browser": "^7.0.2",
    "@capacitor/camera": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/share": "^7.0.2",
    "@capacitor/splash-screen": "^7.0.0",
    "@capgo/capacitor-native-biometric": "^7.5.1",
    "@meshsdk/common": "^1.9.0-beta.84",
    "@meshsdk/core": "^1.9.0-beta.1",
    "@quasar/extras": "^1.16.4",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.2.1",
    "bip39": "^3.1.0",
    "buffer": "^6.0.3",
    "capacitor-secure-storage-plugin": "^0.12.0",
    "date-fns": "^4.1.0",
    "graphql": "^16.11.0",
    "graphql-ws": "^6.0.4",
    "html5-qrcode": "^2.3.8",
    "pinia": "^3.0.1",
    "pinia-plugin-persistedstate": "4.2.0",
    "qrcode": "^1.5.4",
    "qrcode-decoder": "^0.3.4",
    "quasar": "^2.16.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "uuid": "^11.1.0",
    "vue": "^3.5.22",
    "vue-i18n": "^11.0.0",
    "vue-router": "^4.0.0"
  },
  "devDependencies": {
    "@crowdin/cli": "^4.11.0",
    "@eslint/js": "^9.14.0",
    "@intlify/unplugin-vue-i18n": "^4.0.0",
    "@quasar/app-vite": "^2.1.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vue/eslint-config-prettier": "^10.1.0",
    "autoprefixer": "^10.4.2",
    "concurrently": "^8.2.2",
    "dotenv-cli": "^11.0.0",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^16.4.0",
    "postcss": "^8.4.14",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite-plugin-checker": "^0.11.0",
    "vite-plugin-node-polyfills": "^0.22.0",
    "vite-plugin-top-level-await": "^1.4.4",
    "vite-plugin-wasm": "^3.3.0",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.0.0",
    "wait-on": "^7.2.0"
  },
  "engines": {
    "node": "^20 || ^18 || ^16",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
